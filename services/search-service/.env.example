# ── Search Service — environment variables ────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=DEBUG

# Azure AI Search / Elasticsearch
AZURE_SEARCH_ENDPOINT=http://localhost:9200
AZURE_SEARCH_INDEX_NAME=documents
AZURE_SEARCH_API_KEY=

# Azure OpenAI (for embedding the query vector)
AZURE_OPENAI_ENDPOINT=https://<your-resource-name>.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large

# Auth
AUTH_ENABLED=false
AUTH_JWKS_URI=https://login.microsoftonline.com/<tenant-id>/discovery/v2.0/keys
AUTH_AUDIENCE=api://<app-registration-client-id>
AUTH_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]
