# ── Document Service — environment variables ──────────────────────────
ENVIRONMENT=development
LOG_LEVEL=DEBUG

# PostgreSQL
DATABASE_URL=postgresql://allergo:allergo@localhost:5432/allergo

# Azure Blob Storage (used for secure download URL generation)
AZURE_STORAGE_ACCOUNT_URL=http://localhost:10000/devstoreaccount1

# Auth
AUTH_ENABLED=false
AUTH_JWKS_URI=https://login.microsoftonline.com/<tenant-id>/discovery/v2.0/keys
AUTH_AUDIENCE=api://<app-registration-client-id>
AUTH_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]
