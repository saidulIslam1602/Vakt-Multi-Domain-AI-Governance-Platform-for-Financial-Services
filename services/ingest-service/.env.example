# ── Ingest Service — environment variables ─────────────────────────────
# Copy this file to .env for local development (outside Docker).
# In Docker Compose, these are set in docker-compose.yml automatically.

ENVIRONMENT=development
LOG_LEVEL=DEBUG

# PostgreSQL
DATABASE_URL=postgresql://allergo:allergo@localhost:5432/allergo

# Azure Blob Storage (use Azurite locally)
AZURE_BLOB_ACCOUNT_URL=http://localhost:10000/devstoreaccount1

# Azure Service Bus (use RabbitMQ locally)
AZURE_SERVICEBUS_NAMESPACE_FQDN=localhost:5672

# Auth (disabled for local dev; enable in production)
AUTH_ENABLED=false
AUTH_JWKS_URI=https://login.microsoftonline.com/<tenant-id>/discovery/v2.0/keys
AUTH_AUDIENCE=api://<app-registration-client-id>
AUTH_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]
