# ── Frontend — environment variables ──────────────────────────────────
# Next.js reads .env.local in local dev and .env.production for builds.
# Copy this to .env.local for local development.

# Service URLs used by Next.js rewrites (docker-compose / production)
# In docker-compose dev the Next.js next.config.js falls back to localhost.
INGEST_SERVICE_URL=http://ingest-service:8001
DOCUMENT_SERVICE_URL=http://document-service:8002
SEARCH_SERVICE_URL=http://search-service:8003
CHAT_SERVICE_URL=http://chat-service:8004

# Public base URL (used for absolute redirects / og:image etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000
