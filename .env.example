# ============================================================
# Root .env.example  —  copy to .env for local Docker Compose
# ============================================================
# Only ONE variable is required at the root level.
# Per-service variables are in each service's own .env.example
# and are pre-configured in docker-compose.yml for local dev.

# ── Azure OpenAI (required even locally for extraction/chat) ──
AZURE_OPENAI_ENDPOINT=https://<your-resource-name>.openai.azure.com/
